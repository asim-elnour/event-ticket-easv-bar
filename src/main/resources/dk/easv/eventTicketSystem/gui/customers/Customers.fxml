<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="page-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.eventTicketSystem.gui.customers.CustomersController">

    <VBox styleClass="page-content" spacing="0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox style="-fx-padding: 0 0 16 0;">
            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="AS_NEEDED" minHeight="50" pannable="false"
                        styleClass="row-scroll" vbarPolicy="NEVER">
                <content>
                    <HBox styleClass="section-header">
                        <VBox alignment="CENTER_LEFT" spacing="6">
                            <Label minWidth="-Infinity" styleClass="section-label" text="Customers"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label styleClass="muted-text" text="View"/>
                                <ChoiceBox fx:id="viewChoice" minWidth="-Infinity"/>
                            </HBox>
                        </VBox>
                        <Label fx:id="statusLabel" minWidth="-Infinity" styleClass="status-label" text="" visible="false"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="showDeletedButton" minWidth="-Infinity"
                                onAction="#onToggleShowDeletedCustomers"
                                text="Hide Deleted Tickets"/>
                    </HBox>
                </content>
            </ScrollPane>
        </VBox>

        <VBox VBox.vgrow="ALWAYS" minHeight="0">
            <ScrollPane fitToHeight="true"
                        fitToWidth="true"
                        minHeight="85"
                        hbarPolicy="AS_NEEDED"
                        vbarPolicy="AS_NEEDED"
                        style="-fx-background-color: red;"
                        styleClass="table-scroll-container">
                <content>
                    <TableView fx:id="customersTable"
                               minWidth="460"
                               styleClass="data-view">
                        <columns>
                            <TableColumn fx:id="colCustomerTableName" minWidth="180" text="Name"/>
                            <TableColumn fx:id="colCustomerTableEmail" minWidth="220" text="Email"/>
                            <TableColumn fx:id="colCustomerTableTickets" minWidth="110" text="Tickets"/>
                        </columns>
                    </TableView>
                </content>
            </ScrollPane>
        </VBox>

    </VBox>

</AnchorPane>
