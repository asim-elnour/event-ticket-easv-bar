<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../style/style.css"
            styleClass="dialog-root"
            fx:controller="dk.easv.eventTicketSystem.gui.common.ActionConfirmDialogController">

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="scrollable">
            <content>
                <VBox styleClass="dialog-content" spacing="12">
                    <Label fx:id="headerLabel" styleClass="section-label" wrapText="true" text="Confirm action"/>
                    <Label fx:id="contentLabel" wrapText="true"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox styleClass="dialog-actions">
            <Button fx:id="cancelButton" text="Cancel" cancelButton="true" onAction="#onCancel"/>
            <Button fx:id="confirmButton" text="Confirm" defaultButton="true" onAction="#onConfirm"/>
        </HBox>
    </bottom>

</BorderPane>
