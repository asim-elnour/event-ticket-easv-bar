<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane styleClass="page-root"
            xmlns="http://javafx.com/javafx"
            fx:controller="dk.easv.eventTicketSystem.gui.tickets.TicketsController"
            xmlns:fx="http://javafx.com/fxml">

    <VBox styleClass="page-content"
          spacing="0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0">

        <VBox style="-fx-padding: 0 0 16 0;">
            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="AS_NEEDED" minHeight="50" pannable="false"
                        styleClass="row-scroll" vbarPolicy="NEVER">
                <content>
                    <HBox styleClass="section-header">
                        <VBox alignment="CENTER_LEFT" spacing="6">
                            <Label styleClass="section-label" text="Tickets" minWidth="-Infinity"/>
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label styleClass="muted-text" text="View"/>
                                <ChoiceBox fx:id="viewChoice" minWidth="-Infinity"/>
                            </HBox>
                        </VBox>
                        <Label fx:id="statusLabel" text="" visible="false" styleClass="status-label" minWidth="-Infinity"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="showDeletedButton" text="Hide Deleted Tickets" minWidth="-Infinity"
                                onAction="#onToggleShowDeletedTickets"/>
                    </HBox>
                </content>
            </ScrollPane>
        </VBox>

        <VBox VBox.vgrow="ALWAYS" minHeight="0">
            <ScrollPane fitToHeight="true"
                        fitToWidth="true"
                        minHeight="85"
                        hbarPolicy="AS_NEEDED"
                        vbarPolicy="AS_NEEDED"
                        styleClass="table-scroll-container">
                <content>
                    <TableView fx:id="ticketsTable"
                               minWidth="460"
                               styleClass="data-view">
                        <columns>
                            <TableColumn fx:id="colCode" minWidth="180" text="Code"/>
                            <TableColumn fx:id="colCustomerName" minWidth="140" text="Customer"/>
                            <TableColumn fx:id="colEventName" minWidth="160" text="Event"/>
                            <TableColumn fx:id="colStatus" minWidth="110" text="Status"/>
                        </columns>
                    </TableView>
                </content>
            </ScrollPane>
        </VBox>

        <VBox style="-fx-padding: 16 0 0 0;">
            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="AS_NEEDED" minHeight="50" pannable="false"
                        styleClass="row-scroll" vbarPolicy="NEVER">
                <content>
                    <HBox styleClass="actions-row">
                        <Button fx:id="addButton" text="Add Ticket" minWidth="-Infinity" HBox.hgrow="ALWAYS" onAction="#onAddTicket"/>
                        <Button fx:id="redeemButton" text="Redeem Ticket" minWidth="-Infinity" HBox.hgrow="ALWAYS"
                                onAction="#onRedeemTicket"/>
                        <Button fx:id="deleteButton" text="Delete Ticket" minWidth="-Infinity" HBox.hgrow="ALWAYS"
                                onAction="#onDeleteTicket"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="printButton" text="Print Ticket" minWidth="-Infinity" HBox.hgrow="ALWAYS"
                                onAction="#onPrintTicket"/>
                    </HBox>
                </content>
            </ScrollPane>
        </VBox>

    </VBox>

</AnchorPane>
