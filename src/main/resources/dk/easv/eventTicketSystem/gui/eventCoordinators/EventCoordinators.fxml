<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane styleClass="page-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.eventTicketSystem.gui.eventCoordinators.EventCoordinatorsController">

    <VBox styleClass="page-content" minHeight="0" AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">

        <!-- Header: H-scroll only -->
        <ScrollPane fitToWidth="true" fitToHeight="false"
                    hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                    minHeight="50"
                    styleClass="row-scroll">
            <content>
                <HBox styleClass="section-header">
                    <Label styleClass="section-label" text="Event Coordinators" minWidth="-Infinity"/>
                    <Label fx:id="statusLabel" text="" visible="false" styleClass="status-label" minWidth="-Infinity"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="showDeletedButton"
                            text="Hide Deleted Coordinators"
                            minWidth="-Infinity"
                            onAction="#onToggleShowDeletedCoordinators"/>
                </HBox>
            </content>
        </ScrollPane>

        <!-- Table: fills remaining height, internal H+V scroll -->
        <TableView fx:id="usersTable" styleClass="data-view scrollable" minHeight="80" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colFullName" minWidth="140" text="Name"/>
                <TableColumn fx:id="colUserName" minWidth="120" text="Username"/>
                <TableColumn fx:id="colEvent" minWidth="180" text="Event"/>
                <TableColumn fx:id="colStatus" minWidth="100" text="Status"/>
            </columns>
        </TableView>

        <!-- Actions: H-scroll only -->
        <ScrollPane fitToWidth="true" fitToHeight="false"
                    hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                    minHeight="50"
                    styleClass="row-scroll">
            <content>
                <HBox styleClass="actions-row">
                    <Button text="Add Coordinator" minWidth="-Infinity" HBox.hgrow="ALWAYS" onAction="#onAddCoordinator"/>
                    <Button fx:id="removeButton"
                            text="Remove Coordinator"
                            minWidth="-Infinity"
                            HBox.hgrow="ALWAYS"
                            onAction="#onRemoveCoordinator"/>
                </HBox>
            </content>
        </ScrollPane>

    </VBox>

</AnchorPane>
