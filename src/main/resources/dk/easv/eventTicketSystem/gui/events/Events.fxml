<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane styleClass="page-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.eventTicketSystem.gui.events.EventsController">

    <VBox styleClass="page-content" spacing="0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <VBox style="-fx-padding: 0 0 16 0;">
            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="AS_NEEDED" minHeight="50" pannable="false"
                        styleClass="row-scroll" vbarPolicy="NEVER">
                <content>
                    <HBox styleClass="section-header">
                        <Label fx:id="sectionTitleLabel" minWidth="-Infinity" styleClass="section-label" text="Events"/>
                        <Label fx:id="statusLabel" minWidth="-Infinity" styleClass="status-label" text="" visible="false"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="showDeletedButton" minWidth="-Infinity" onAction="#onToggleShowDeletedEvents"
                                text="Hide Deleted Events"/>
                    </HBox>
                </content>
            </ScrollPane>
        </VBox>

        <VBox VBox.vgrow="ALWAYS" minHeight="0">
            <ScrollPane fitToHeight="true"
                        fitToWidth="true"
                        minHeight="85"
                        hbarPolicy="AS_NEEDED"
                        vbarPolicy="AS_NEEDED"
                        style="-fx-background-color: red;"
                        styleClass="table-scroll-container">
                <content>
                    <TableView fx:id="eventsTable"
                               minWidth="460"
                               styleClass="data-view">
                        <columns>
                            <TableColumn fx:id="colName" minWidth="170" text="Name"/>
                            <TableColumn fx:id="colLocation" minWidth="170" text="Location"/>
                            <TableColumn fx:id="colStart" minWidth="150" text="Start"/>
                            <TableColumn fx:id="colStatus" minWidth="120" text="Status"/>
                        </columns>
                    </TableView>
                </content>
            </ScrollPane>
        </VBox>

        <VBox style="-fx-padding: 16 0 0 0;">
            <ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="AS_NEEDED" minHeight="50" pannable="false"
                        styleClass="row-scroll" vbarPolicy="NEVER">
                <content>
                    <HBox styleClass="actions-row">
                        <Button fx:id="addButton" minWidth="-Infinity" onAction="#onAddEvent" text="Add Event"
                                HBox.hgrow="ALWAYS"/>
                        <Button fx:id="editButton" minWidth="-Infinity" onAction="#onEditEvent" text="Edit Event"
                                HBox.hgrow="ALWAYS"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="deleteButton" minWidth="-Infinity" onAction="#onDeleteEvent" text="Delete Event"
                                HBox.hgrow="ALWAYS"/>
                    </HBox>
                </content>
            </ScrollPane>
        </VBox>

    </VBox>

</AnchorPane>
