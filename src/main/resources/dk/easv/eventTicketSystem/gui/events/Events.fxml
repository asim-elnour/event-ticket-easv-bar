<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane styleClass="page-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dk.easv.eventTicketSystem.gui.events.EventsController">

    <VBox styleClass="page-content"
          minHeight="0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0">

        <!-- Header: H-scroll only — button stays at right edge when wide, scrolls H when narrow -->
        <ScrollPane fitToWidth="true" fitToHeight="false"
                    hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                    minHeight="50"
                    styleClass="row-scroll">
            <content>
                <HBox styleClass="section-header">
                    <Label fx:id="sectionTitleLabel" styleClass="section-label" text="Events" minWidth="-Infinity"/>
                    <Label fx:id="statusLabel" text="" visible="false" styleClass="status-label" minWidth="-Infinity"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="showDeletedButton" text="Hide Deleted Events" minWidth="-Infinity" onAction="#onToggleShowDeletedEvents"/>
                </HBox>
            </content>
        </ScrollPane>

        <!-- Table: fills remaining height, internal H+V scroll — no ellipsis -->
        <TableView fx:id="eventsTable" styleClass="data-view scrollable" minHeight="80" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName" minWidth="180" text="Name"/>
                <TableColumn fx:id="colLocation" minWidth="180" text="Location"/>
                <TableColumn fx:id="colStart" minWidth="160" text="Start"/>
                <TableColumn fx:id="colStatus" minWidth="120" text="Status"/>
            </columns>
        </TableView>

        <!-- Actions: H-scroll only — buttons stay full size, scroll H when narrow -->
        <ScrollPane fitToWidth="true" fitToHeight="false"
                    hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                    minHeight="50"
                    styleClass="row-scroll">
            <content>
                <HBox styleClass="actions-row">
                    <Button fx:id="addButton" text="Add Event" minWidth="-Infinity" HBox.hgrow="ALWAYS" onAction="#onAddEvent"/>
                    <Button fx:id="editButton" text="Edit Event" minWidth="-Infinity" HBox.hgrow="ALWAYS" onAction="#onEditEvent"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="deleteButton" text="Delete Event" minWidth="-Infinity" HBox.hgrow="ALWAYS" onAction="#onDeleteEvent"/>
                </HBox>
            </content>
        </ScrollPane>

    </VBox>

</AnchorPane>
